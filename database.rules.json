{
  "rules": {
    ".read": false,
    ".write": false,
    "games": {
      "$gameCode": {
        ".read": true,
        "clues": {
          "$targetId": {
            "$memberId": {
              ".write": "root.child('games').child($gameCode).child('meta/phase').val() === 'clue-submission'",
              "submittedAt": {
                ".validate": "newData.isNumber()"
              },
              "$slot": {
                ".validate": "newData.isString() && newData.val().length < 1000"
              }
            }
          }
        },
        "meta": {
          ".write": false
        },
        "rounds": {
          ".write": false
        },
        "scores": {
          ".write": false
        },
        "members": {
          ".write": false
        }
      }
    }
  }
}
