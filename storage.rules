rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Member portrait photos (uploaded during game setup)
    match /members/{gameCode}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Clue images (uploaded during clue submission)
    match /clues/{gameCode}/{targetId}/{giverId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
